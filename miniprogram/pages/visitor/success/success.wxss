.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0;
}

/* 成功头部 */
.success-header {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  padding: 60rpx 40rpx 80rpx;
  text-align: center;
  color: #fff;
}

.success-icon {
  margin-bottom: 30rpx;
}

.icon-circle {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.icon-check {
  width: 70rpx;
  height: 35rpx;
  border-left: 6rpx solid #fff;
  border-bottom: 6rpx solid #fff;
  transform: rotate(-45deg);
  position: relative;
  top: -10rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.success-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  line-height: 1.6;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  margin: -40rpx 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #fafafa;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.info-row .value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}

.status-text {
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-confirmed {
  background: #f6ffed;
  color: #52c41a;
}

.status-rejected {
  background: #fff1f0;
  color: #f5222d;
}

.status-cancelled {
  background: #f5f5f5;
  color: #999;
}

/* 提示卡片 */
.tips-card {
  background: #fff;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.tips-item:last-child {
  margin-bottom: 0;
}

.tips-bullet {
  color: #1890ff;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #1890ff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #1890ff;
}

.btn-hover {
  opacity: 0.8;
}
