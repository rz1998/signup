.cover-image {
  width: 100%;
  height: 400rpx;
  background: #f0f0f0;
}

.info-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.activity-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

.status-published {
  background: #e6f7ff;
  color: #1890ff;
}

.status-ongoing {
  background: #f6ffed;
  color: #52c41a;
}

.status-ended, .status-cancelled {
  background: #fff1f0;
  color: #f5222d;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  color: #666;
  font-size: 28rpx;
}

.value {
  color: #333;
  font-size: 28rpx;
}

.description-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333;
}

.description {
  font-size: 28rpx;
  line-height: 1.8;
  color: #666;
  white-space: pre-wrap;
}

.register-section {
  background: #fff;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item .label {
  display: block;
  margin-bottom: 12rpx;
  color: #333;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.register-btn {
  margin-top: 30rpx;
}

.notice {
  text-align: center;
  padding: 40rpx;
  color: #999;
  background: #fff;
  border-radius: 12rpx;
}

.picker-view {
  line-height: 80rpx;
  color: #666;
}

.field-error {
  display: block;
  color: #ff4d4f;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 单选/多选样式 */
.radio-group, .checkbox-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 10rpx 0;
}

.radio-group label, .checkbox-group label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
}
