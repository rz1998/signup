.header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
}

.back {
  color: #1890ff;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
}

.filter {
  padding: 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.filter-picker {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.registration-list {
  padding: 0 20rpx;
}

.registration-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-confirmed {
  background: #f6ffed;
  color: #52c41a;
}

.status-cancelled {
  background: #fff1f0;
  color: #f5222d;
}

.status-completed {
  background: #e6f7ff;
  color: #1890ff;
}

.item-body {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.label {
  color: #999;
  min-width: 140rpx;
}

.value {
  color: #666;
}

.item-footer {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #ccc;
  font-size: 24rpx;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
