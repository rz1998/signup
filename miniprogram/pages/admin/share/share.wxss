.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #fff;
}

.back {
  color: #1890ff;
  font-size: 28rpx;
  min-width: 80rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
}

.placeholder {
  min-width: 80rpx;
}

/* Tab bar */
.tab-bar {
  display: flex;
  background: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #1890ff;
  border-bottom-color: #1890ff;
  font-weight: 600;
}

.tab-content {
  padding: 0 20rpx 40rpx;
}

/* Sections */
.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

/* Activity selector */
.activity-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.selected-activity {
  font-size: 28rpx;
  color: #333;
}

.selector-placeholder {
  font-size: 28rpx;
  color: #999;
}

.selector-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* Share actions */
.share-actions {
  display: flex;
  gap: 20rpx;
}

.share-action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.action-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.action-label {
  font-size: 26rpx;
  color: #333;
}

/* Empty / Loading */
.empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
  background: #fff;
  border-radius: 12rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #ccc;
  font-size: 24rpx;
}

/* Records list */
.records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.record-activity {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.record-type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.record-type.type-link {
  background: #e6f7ff;
  color: #1890ff;
}

.record-type.type-qrcode {
  background: #f6ffed;
  color: #52c41a;
}

.record-url {
  font-size: 22rpx;
  color: #1890ff;
  font-family: monospace;
  background: #f5f5f5;
  padding: 12rpx;
  border-radius: 6rpx;
  word-break: break-all;
  margin-bottom: 12rpx;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-visits {
  font-size: 24rpx;
  color: #666;
}

.record-time {
  font-size: 22rpx;
  color: #999;
}

/* Activity picker sheet */
.picker-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 60vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
}

.sheet-body {
  max-height: 50vh;
  padding: 10rpx 0;
}

.picker-item {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-item:active {
  background: #f5f5f5;
}

/* Form modal */
.form-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.form-container {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
}

.close {
  font-size: 48rpx;
  color: #999;
}

.form-body {
  padding: 30rpx;
}

.share-info {
  margin-bottom: 20rpx;
}

.share-activity-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.share-url-container {
  margin-bottom: 20rpx;
}

.share-url-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.share-url-box {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  word-break: break-all;
  color: #1890ff;
  font-family: monospace;
}

.share-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.qrcode-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
}

.qrcode-placeholder {
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  color: #999;
  font-size: 28rpx;
}

.form-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.form-footer button {
  flex: 1;
}
