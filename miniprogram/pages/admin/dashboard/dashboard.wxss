.container {
  padding: 20rpx;
}

.user-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  padding: 40rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 20rpx;
}

.info .nickname {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.info .role {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 8rpx;
}

.logout {
  color: #fff;
  font-size: 28rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-warning {
  color: #fa8c16;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.menu-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.menu-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.menu-label {
  font-size: 22rpx;
  color: #666;
}

.recent-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.more {
  font-size: 24rpx;
  color: #1890ff;
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.recent-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}

.status-published {
  color: #1890ff;
}

.status-ongoing {
  color: #52c41a;
}

.status-ended, .status-cancelled {
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
}
