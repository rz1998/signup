.header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.back {
  color: #1890ff;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
}

.add-btn {
  background: #1890ff;
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.add-btn text {
  color: #fff;
}

/* 搜索栏 */
.search-bar {
  padding: 0 20rpx 20rpx;
}

.search-input {
  height: 72rpx;
  padding: 0 24rpx;
  background: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}

/* 筛选栏 */
.filter-bar {
  padding: 0 20rpx 20rpx;
}

.filter-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #1890ff;
  border: 1rpx solid #1890ff;
}

/* 分支机构列表 */
.branch-list {
  padding: 0 20rpx;
}

.branch-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.branch-info {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.meta {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.status-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  margin-top: 8rpx;
}

.status-active {
  background: #f6ffed;
  color: #52c41a;
}

.status-inactive {
  background: #fff1f0;
  color: #f5222d;
}

.actions {
  flex-shrink: 0;
  margin-left: 20rpx;
  display: flex;
  gap: 10rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #ccc;
  font-size: 24rpx;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 表单弹窗 */
.form-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.form-container {
  width: 85%;
  max-height: 85vh;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
}

.close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.form-body {
  padding: 30rpx;
  max-height: 65vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item .label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-item .input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

.form-footer button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.form-footer button:first-child {
  background: #f5f5f5;
  color: #666;
}

.form-footer button:last-child {
  background: #1890ff;
  color: #fff;
}

.picker-value {
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

/* 负责人选择器 */
.leader-selector {
  width: 100%;
}

.leader-selected-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #f0f7ff 0%, #e6f4ff 100%);
  border: 2rpx solid #1890ff;
  border-radius: 16rpx;
}

.leader-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.leader-avatar .avatar-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.leader-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.leader-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.leader-phone {
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}

.leader-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.change-btn {
  padding: 8rpx 20rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.leader-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: #fafafa;
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.select-btn {
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 用户选择弹窗 */
.user-picker-modal {
  width: 90%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.close-icon {
  width: 56rpx;
  height: 56rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}

.picker-toolbar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-box .search-input {
  flex: 1;
  height: 72rpx;
  background: transparent;
  font-size: 28rpx;
}

.add-user-btn {
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #fff;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}

.user-scroll-list {
  flex: 1;
  max-height: 50vh;
  padding: 20rpx 30rpx;
}

.user-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.user-card.selected {
  background: linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%);
  border-color: #1890ff;
}

.user-card-left {
  display: flex;
  align-items: center;
}

.user-avatar-lg {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.user-avatar-lg .avatar-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.user-name-lg {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.user-phone-lg {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.user-card-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.role-tag {
  padding: 6rpx 16rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666;
}

.role-tag.admin {
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  color: #fa8c16;
}

.selected-check {
  width: 44rpx;
  height: 44rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.user-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}

/* 快速新增用户面板 */
.quick-add-panel {
  border-top: 1rpx solid #f0f0f0;
  padding: 30rpx;
  background: #fff;
}

.quick-add-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.quick-add-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.close-icon-sm {
  width: 44rpx;
  height: 44rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
}

.quick-add-body {
  margin-bottom: 30rpx;
}

.quick-form-item {
  margin-bottom: 24rpx;
}

.quick-form-item:last-child {
  margin-bottom: 0;
}

.quick-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.quick-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.quick-add-footer {
  display: flex;
  gap: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
}
