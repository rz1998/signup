<view class="container">
  <view class="header">
    <view class="back" bindtap="goBack">← 返回</view>
    <view class="title">分支机构管理</view>
    <view class="add-btn" bindtap="showAddForm">
      <text>+ 添加机构</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索分支机构名称" bindconfirm="onSearch" />
  </view>

  <!-- 公司筛选 -->
  <view class="filter-bar">
    <picker mode="selector" range="{{companies}}" range-key="name" bindchange="onFilterCompanyChange">
      <view class="filter-tag">{{filterCompanyLabel}}</view>
    </picker>
  </view>

  <view wx:if="{{loading && branches.length === 0}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{branches.length === 0}}" class="empty">
    <text>暂无分支机构</text>
  </view>

  <view wx:else class="branch-list">
    <view wx:for="{{branches}}" wx:key="id" class="branch-item">
      <view class="branch-info">
        <view class="name">{{item.name}}</view>
        <view class="meta">
          <text>所属公司：{{item.companyName || '-'}}</text>
        </view>
        <view class="meta">
          <text>负责人：{{item.leaderName || '-'}}  电话：{{item.leaderPhone || '-'}}</text>
        </view>
        <view class="status-badge status-{{item.status}}">
          {{item.status === 'active' ? '正常' : '禁用'}}
        </view>
      </view>
      <view class="actions">
        <button size="mini" bindtap="showEditForm" data-branch="{{item}}">编辑</button>
        <button size="mini" type="warn" bindtap="deleteBranch" data-id="{{item.id}}">删除</button>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{!hasMore && branches.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>

  <!-- 表单弹窗 -->
  <view wx:if="{{showForm}}" class="form-mask">
    <view class="form-container">
      <view class="form-header">
        <view class="form-title">{{isEdit ? '编辑分支机构' : '添加分支机构'}}</view>
        <view class="close" bindtap="hideForm">×</view>
      </view>

      <view class="form-body">
        <view class="form-item">
          <text class="label">所属公司 *</text>
          <picker mode="selector" range="{{formCompanies}}" range-key="name" bindchange="onFormCompanyChange">
            <view class="picker-value">{{formCompanyLabel}}</view>
          </picker>
        </view>

        <view class="form-item">
          <text class="label">机构名称 *</text>
          <input class="input" value="{{formData.name}}" bindinput="onInput" data-field="name" placeholder="请输入分支机构名称" />
        </view>

        <view class="form-item">
          <text class="label">负责人 *</text>
          <view class="leader-selector">
            <view class="leader-selected" wx:if="{{selectedUser}}" bindtap="showUserSelector">
              <text class="leader-name">{{selectedUser.name}}</text>
              <text class="leader-phone">{{selectedUser.phone}}</text>
            </view>
            <button wx:else size="mini" type="primary" bindtap="showUserSelector">选择负责人</button>
            <button wx:if="{{selectedUser}}" size="mini" bindtap="clearSelectedUser">清除</button>
          </view>
        </view>

        <view class="form-item" wx:if="{{isEdit}}">
          <text class="label">状态</text>
          <picker mode="selector" range="{{statuses}}" range-key="label" bindchange="onStatusChange">
            <view class="picker-value">{{statusLabel}}</view>
          </picker>
        </view>
      </view>

      <view class="form-footer">
        <button bindtap="hideForm">取消</button>
        <button type="primary" bindtap="submitForm">保存</button>
      </view>
    </view>
  </view>

  <!-- 用户选择弹窗 -->
  <view wx:if="{{showUserPicker}}" class="form-mask">
    <view class="form-container user-picker-container">
      <view class="form-header">
        <view class="form-title">选择负责人</view>
        <view class="close" bindtap="hideUserPicker">×</view>
      </view>

      <view class="user-picker-toolbar">
        <input class="search-input" placeholder="搜索用户姓名或电话" bindinput="onUserSearch" value="{{userSearchKey}}" />
        <button size="mini" type="primary" bindtap="showQuickAddUser">新增用户</button>
      </view>

      <view class="user-list">
        <view wx:for="{{filteredUserList}}" wx:key="id" class="user-item {{item.id === selectedUserId ? 'selected' : ''}}" bindtap="selectUser" data-user="{{item}}">
          <view class="user-info">
            <text class="user-name">{{item.name}}</text>
            <text class="user-phone">{{item.phone}}</text>
          </view>
          <view class="user-role">
            <text class="role-badge">{{item.role === 'branch_admin' ? '机构管理员' : item.role}}</text>
          </view>
          <view wx:if="{{item.id === selectedUserId}}" class="check-icon">✓</view>
        </view>
        <view wx:if="{{filteredUserList.length === 0}}" class="empty">
          <text>暂无用户</text>
        </view>
      </view>

      <!-- 快速新增用户表单 -->
      <view wx:if="{{showQuickAddUser}}" class="quick-add-form">
        <view class="quick-add-title">新增用户（设为机构管理员）</view>
        <view class="form-item">
          <text class="label">姓名 *</text>
          <input class="input" value="{{quickAddData.name}}" bindinput="onQuickAddInput" data-field="name" placeholder="请输入姓名" />
        </view>
        <view class="form-item">
          <text class="label">电话 *</text>
          <input class="input" value="{{quickAddData.phone}}" bindinput="onQuickAddInput" data-field="phone" placeholder="请输入电话" />
        </view>
        <view class="form-item">
          <text class="label">密码 *</text>
          <input class="input" type="password" value="{{quickAddData.password}}" bindinput="onQuickAddInput" data-field="password" placeholder="请输入密码" />
        </view>
        <view class="form-footer">
          <button bindtap="cancelQuickAddUser">取消</button>
          <button type="primary" bindtap="confirmQuickAddUser">确认添加</button>
        </view>
      </view>
    </view>
  </view>
</view>
