<view class="container">
  <view class="header">
    <view class="back" bindtap="goBack">← 返回</view>
    <view class="title">分支机构管理</view>
    <view class="add-btn" bindtap="showAddForm">
      <text>+ 添加机构</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索分支机构名称" bindconfirm="onSearch" />
  </view>

  <!-- 公司筛选 -->
  <view class="filter-bar">
    <picker mode="selector" range="{{companies}}" range-key="name" bindchange="onFilterCompanyChange">
      <view class="filter-tag">{{filterCompanyLabel}}</view>
    </picker>
  </view>

  <view wx:if="{{loading && branches.length === 0}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{branches.length === 0}}" class="empty">
    <text>暂无分支机构</text>
  </view>

  <view wx:else class="branch-list">
    <view wx:for="{{branches}}" wx:key="id" class="branch-item">
      <view class="branch-info">
        <view class="name">{{item.name}}</view>
        <view class="meta">
          <text>所属公司：{{item.companyName || '-'}}</text>
        </view>
        <view class="meta">
          <text>负责人：{{item.leaderName || '-'}}  电话：{{item.leaderPhone || '-'}}</text>
        </view>
        <view class="status-badge status-{{item.status}}">
          {{item.status === 'active' ? '正常' : '禁用'}}
        </view>
      </view>
      <view class="actions">
        <button size="mini" bindtap="showEditForm" data-branch="{{item}}">编辑</button>
        <button size="mini" type="warn" bindtap="deleteBranch" data-id="{{item.id}}">删除</button>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{!hasMore && branches.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>

  <!-- 表单弹窗 -->
  <view wx:if="{{showForm}}" class="form-mask">
    <view class="form-container">
      <view class="form-header">
        <view class="form-title">{{isEdit ? '编辑分支机构' : '添加分支机构'}}</view>
        <view class="close" bindtap="hideForm">×</view>
      </view>

      <view class="form-body">
        <view class="form-item">
          <text class="label">所属公司 *</text>
          <picker mode="selector" range="{{formCompanies}}" range-key="name" bindchange="onFormCompanyChange">
            <view class="picker-value">{{formCompanyLabel}}</view>
          </picker>
        </view>

        <view class="form-item">
          <text class="label">机构名称 *</text>
          <input class="input" value="{{formData.name}}" bindinput="onInput" data-field="name" placeholder="请输入分支机构名称" />
        </view>

        <view class="form-item">
          <text class="label">负责人 *</text>
          <view class="leader-selector" bindtap="showUserSelector">
            <!-- 已选择负责人 -->
            <view wx:if="{{selectedUser}}" class="leader-selected-card">
              <view class="leader-avatar">
                <text class="avatar-text">{{selectedUser.name.substr(0,1)}}</text>
              </view>
              <view class="leader-info">
                <text class="leader-name">{{selectedUser.name}}</text>
                <text class="leader-phone">{{selectedUser.phone}}</text>
              </view>
              <view class="leader-actions">
                <view class="change-btn">更换</view>
                <view class="clear-btn" catchtap="clearSelectedUser">×</view>
              </view>
            </view>
            <!-- 未选择 -->
            <view wx:else class="leader-empty">
              <view class="empty-icon">👤</view>
              <text class="empty-text">请选择机构负责人</text>
              <view class="select-btn">选择负责人</view>
            </view>
          </view>
        </view>

        <view class="form-item" wx:if="{{isEdit}}">
          <text class="label">状态</text>
          <picker mode="selector" range="{{statuses}}" range-key="label" bindchange="onStatusChange">
            <view class="picker-value">{{statusLabel}}</view>
          </picker>
        </view>
      </view>

      <view class="form-footer">
        <button bindtap="hideForm">取消</button>
        <button type="primary" bindtap="submitForm">保存</button>
      </view>
    </view>
  </view>

  <!-- 用户选择弹窗 -->
  <view wx:if="{{showUserPicker}}" class="form-mask" catchtap="hideUserPicker">
    <view class="user-picker-modal" catchtap="stopPropagation">
      <view class="picker-header">
        <view class="picker-title">选择负责人</view>
        <view class="close-icon" bindtap="hideUserPicker">×</view>
      </view>

      <view class="picker-toolbar">
        <view class="search-box">
          <text class="search-icon">🔍</text>
          <input class="search-input" placeholder="搜索姓名或电话" bindinput="onUserSearch" value="{{userSearchKey}}" />
        </view>
        <view class="add-user-btn" bindtap="showQuickAddUser">+ 新增</view>
      </view>

      <scroll-view class="user-scroll-list" scroll-y>
        <view wx:for="{{filteredUserList}}" wx:key="id" class="user-card {{item.id === selectedUserId ? 'selected' : ''}}" bindtap="selectUser" data-user="{{item}}">
          <view class="user-card-left">
            <view class="user-avatar-lg">
              <text class="avatar-text">{{item.name.substr(0,1)}}</text>
            </view>
            <view class="user-details">
              <text class="user-name-lg">{{item.name}}</text>
              <text class="user-phone-lg">{{item.phone}}</text>
            </view>
          </view>
          <view class="user-card-right">
            <view class="role-tag {{item.role === 'branch_admin' ? 'admin' : ''}}">
              {{item.role === 'branch_admin' ? '机构管理员' : '用户'}}
            </view>
            <view wx:if="{{item.id === selectedUserId}}" class="selected-check">✓</view>
          </view>
        </view>
        
        <view wx:if="{{filteredUserList.length === 0}}" class="user-empty">
          <text class="empty-hint">未找到匹配的用户</text>
        </view>
      </scroll-view>

      <!-- 快速新增用户表单 -->
      <view wx:if="{{showQuickAddUser}}" class="quick-add-panel">
        <view class="quick-add-header">
          <text class="quick-add-title">新增机构管理员</text>
          <view class="close-icon-sm" bindtap="cancelQuickAddUser">×</view>
        </view>
        <view class="quick-add-body">
          <view class="quick-form-item">
            <text class="quick-label">姓名</text>
            <input class="quick-input" value="{{quickAddData.name}}" bindinput="onQuickAddInput" data-field="name" placeholder="请输入姓名" />
          </view>
          <view class="quick-form-item">
            <text class="quick-label">电话</text>
            <input class="quick-input" value="{{quickAddData.phone}}" bindinput="onQuickAddInput" data-field="phone" placeholder="请输入电话" />
          </view>
          <view class="quick-form-item">
            <text class="quick-label">密码</text>
            <input class="quick-input" type="password" value="{{quickAddData.password}}" bindinput="onQuickAddInput" data-field="password" placeholder="请输入密码" />
          </view>
        </view>
        <view class="quick-add-footer">
          <button class="btn-cancel" bindtap="cancelQuickAddUser">取消</button>
          <button class="btn-confirm" type="primary" bindtap="confirmQuickAddUser">确认添加</button>
        </view>
      </view>
    </view>
  </view>
</view>
