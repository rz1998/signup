<view class="container">
  <view class="header">
    <view class="back" bindtap="goBack">← 返回</view>
    <view class="title">个人设置</view>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>
  
  <view wx:else class="profile-form">
    <!-- 头像 -->
    <view class="avatar-section">
      <image class="avatar" src="{{userInfo.avatar || '/assets/icons/default-avatar.png'}}" mode="aspectFill" />
      <button size="mini" bindtap="chooseAvatar">更换头像</button>
    </view>
    
    <!-- 表单 -->
    <view class="form-section">
      <view class="form-item">
        <text class="label">用户名</text>
        <input class="input" value="{{userInfo.username}}" disabled />
      </view>
      
      <view class="form-item">
        <text class="label">昵称</text>
        <input 
          class="input" 
          data-field="nickname" 
          value="{{formData.nickname}}" 
          bindinput="onInput" 
          placeholder="请输入昵称" 
        />
      </view>
      
      <view class="form-item">
        <text class="label">手机号</text>
        <input 
          class="input" 
          type="number"
          data-field="phone" 
          value="{{formData.phone}}" 
          bindinput="onInput" 
          placeholder="请输入手机号" 
        />
      </view>
      
      <view class="form-item">
        <text class="label">邮箱</text>
        <input 
          class="input" 
          data-field="email" 
          value="{{formData.email}}" 
          bindinput="onInput" 
          placeholder="请输入邮箱" 
        />
      </view>
    </view>
    
    <!-- 按钮 -->
    <view class="btn-section">
      <button type="primary" bindtap="submitForm" disabled="{{submitting}}">
        {{submitting ? '保存中...' : '保存修改'}}
      </button>
      <button bindtap="onLogout">退出登录</button>
    </view>
  </view>
</view>
