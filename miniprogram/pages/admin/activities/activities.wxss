.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.back, .add-btn {
  color: #1890ff;
  font-size: 28rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 0 20rpx 20rpx;
}

.filter-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #1890ff;
  border: 1rpx solid #1890ff;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
}

.activity-list {
  padding: 0 20rpx;
}

.activity-item {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.cover {
  width: 180rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.content {
  flex: 1;
  min-width: 0;
}

.content .title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.meta, .time {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.meta text {
  margin-right: 16rpx;
}

.status-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  margin-top: 8rpx;
}

.status-draft {
  background: #f5f5f5;
  color: #999;
}

.status-published {
  background: #e6f7ff;
  color: #1890ff;
}

.status-ongoing {
  background: #f6ffed;
  color: #52c41a;
}

.status-ended {
  background: #fff1f0;
  color: #f5222d;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  justify-content: center;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #ccc;
  font-size: 24rpx;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 表单弹窗 */
.form-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.form-container {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
}

.close {
  font-size: 48rpx;
  color: #999;
}

.form-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item .label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.form-item .input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.datetime-picker {
  display: flex;
  gap: 20rpx;
}

.datetime-picker picker {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
}

.datetime-picker .picker-value {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
}

.form-item .textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.form-footer button {
  flex: 1;
}

/* 分享样式 */
.share-url-container {
  margin-bottom: 20rpx;
}

.share-url-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.share-url-box {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  word-break: break-all;
  color: #1890ff;
  font-family: monospace;
}

.share-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
}

.qrcode-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
  background: #fff;
}

.qrcode-placeholder {
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  color: #999;
  font-size: 28rpx;
}
