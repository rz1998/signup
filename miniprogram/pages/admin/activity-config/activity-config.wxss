.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #fff;
}

.back, .add-btn {
  color: #1890ff;
  font-size: 28rpx;
  min-width: 80rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
}

.placeholder {
  min-width: 80rpx;
}

.activity-info {
  padding: 16rpx 20rpx;
  background: #e6f7ff;
  margin: 0 20rpx 0;
  border-radius: 8rpx;
}

.activity-name {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: 600;
}

/* Tab bar */
.tab-bar {
  display: flex;
  background: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #1890ff;
  border-bottom-color: #1890ff;
  font-weight: 600;
}

.tab-content {
  padding: 0 20rpx 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* Field list */
.field-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.field-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  gap: 16rpx;
}

.field-drag {
  width: 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.field-content {
  flex: 1;
  min-width: 0;
}

.field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.field-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.field-name {
  font-size: 22rpx;
  color: #999;
  font-family: monospace;
}

.field-type {
  font-size: 22rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.field-required {
  font-size: 22rpx;
  color: #ff4d4f;
  background: #fff1f0;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.field-placeholder {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.field-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: center;
}

.action-up, .action-down {
  font-size: 22rpx;
  color: #1890ff;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background: #e6f7ff;
  line-height: 1.4;
}

.action-up.disabled, .action-down.disabled {
  color: #ccc;
  background: #f5f5f5;
}

.action-edit {
  font-size: 22rpx;
  color: #1890ff;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background: #e6f7ff;
}

.action-delete {
  font-size: 22rpx;
  color: #ff4d4f;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background: #fff1f0;
}

/* Style preview */
.style-preview {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.preview-cover {
  width: 100%;
  height: 300rpx;
  background: #f0f0f0;
}

.preview-title {
  padding: 20rpx 20rpx 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.preview-subtitle {
  padding: 0 20rpx 20rpx;
  font-size: 26rpx;
  color: #666;
}

.style-info {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.style-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 16rpx;
}

.style-item:last-child {
  border-bottom: none;
}

.style-label {
  font-size: 26rpx;
  color: #666;
  min-width: 120rpx;
}

.style-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.color-swatch {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
}

/* Loading / Empty */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
  background: #fff;
  border-radius: 12rpx;
}

.empty-tip {
  display: block;
  font-size: 24rpx;
  margin-top: 12rpx;
  color: #bbb;
}

/* Form modal */
.form-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.form-container {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
}

.close {
  font-size: 48rpx;
  color: #999;
}

.form-body {
  padding: 30rpx;
  max-height: 65vh;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item .label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.form-item .input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-item .textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-item-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-item-switch .label {
  margin-bottom: 0;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.form-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.form-footer button {
  flex: 1;
}

/* Cover uploader */
.cover-uploader {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.cover-preview {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #ccc;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.cover-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}
