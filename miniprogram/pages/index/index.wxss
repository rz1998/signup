.header {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  padding: 40rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.welcome {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header .subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #333;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.activity-cover {
  width: 100%;
  height: 300rpx;
  background: #f0f0f0;
}

.activity-info {
  padding: 20rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #333;
}

.activity-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #666;
}

.activity-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.activity-status {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.status-published {
  background: #e6f7ff;
  color: #1890ff;
}

.status-ongoing {
  background: #f6ffed;
  color: #52c41a;
}

.status-ended, .status-cancelled {
  background: #fff1f0;
  color: #f5222d;
}

.admin-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-top: 30rpx;
  color: #666;
}

.arrow {
  color: #999;
}
